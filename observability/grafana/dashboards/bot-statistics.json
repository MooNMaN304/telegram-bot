{
  "title": "Telegram Bot — полный мониторинг",
  "uid": "telegram-bot-full-monitoring",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "tags": ["telegram-bot", "parsing", "prometheus"],
  "panels": [
    {
      "id": 9001,
      "title": "🖥 Состояние серверов и сервисов",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "🔥 Bot Frankfurt (live)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"telegram-bot\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.5 }] },
          "mappings": [{ "type": "value", "options": { "0": { "text": "🔴 DOWN", "color": "red" }, "1": { "text": "✅ UP", "color": "green" } } }],
          "unit": "none"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }
    },
    {
      "id": 2,
      "title": "📊 Bot request rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(bot_requests_total[5m])", "legendFormat": "All", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "reqps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }
    },
    {
      "id": 3,
      "title": "❌ Bot errors",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(bot_errors_total)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "none"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }
    },
    {
      "id": 4,
      "title": "📊 Requests by handler",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(bot_requests_total[5m])", "legendFormat": "{{handler}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "reqps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 }
    },
    {
      "id": 5,
      "title": "📊 Error rate by type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(bot_errors_total[5m])", "legendFormat": "{{error_type}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 30, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "cps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 }
    },
    {
      "id": 9002,
      "title": "⚠️ Ошибки из логов",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "id": 6,
      "title": "📋 Последние ошибки (Loki)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{ "expr": "{service=~\"telegram-bot|celery-worker\"} | json | level=\"ERROR\"", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogsMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 9003,
      "title": "🎬 Парсинг",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "id": 7,
      "title": "✅ Парсинг успешно",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(parsing_tasks_total{status=\"success\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 25 }
    },
    {
      "id": 8,
      "title": "❌ Парсинг ошибок",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(parsing_tasks_total{status=\"failed\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 25 }
    },
    {
      "id": 9,
      "title": "🔄 В процессе",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(parsing_in_progress)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 3 }] }, "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 25 }
    },
    {
      "id": 10,
      "title": "🎬 Фильмов найдено",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(movies_found_total) by (cinema)", "legendFormat": "{{cinema}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 25 }
    },
    {
      "id": 11,
      "title": "🎫 Сеансов найдено",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(sessions_found_total) by (cinema)", "legendFormat": "{{cinema}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 25 }
    },
    {
      "id": 12,
      "title": "⏱ Длит-ть парсинга (p99)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(parsing_duration_seconds_bucket[5m])) by (le, parser))", "legendFormat": "{{parser}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" } },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 25 }
    },
    {
      "id": 13,
      "title": "🚨 Капча всего",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(captcha_detections_total)", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 3 }, { "color": "red", "value": 10 }] }, "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 25 }
    },
    {
      "id": 14,
      "title": "🔄 Пересозд. драйвера",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(driver_operations_total{operation=\"restart\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 15 }] }, "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 25 }
    },
    {
      "id": 15,
      "title": "📊 Parsing tasks rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(parsing_tasks_total{status=\"success\"}[5m])", "legendFormat": "✅ {{parser}}", "refId": "A" },
        { "expr": "rate(parsing_tasks_total{status=\"failed\"}[5m])", "legendFormat": "❌ {{parser}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "cps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 }
    },
    {
      "id": 16,
      "title": "📊 Parsing duration (p50/p95/p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(parsing_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(parsing_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(parsing_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "s" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 }
    },
    {
      "id": 17,
      "title": "📊 Browser & driver rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(driver_operations_total[5m])", "legendFormat": "driver: {{operation}}", "refId": "A" },
        { "expr": "rate(captcha_detections_total[5m])", "legendFormat": "captcha", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "cps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 }
    },
    {
      "id": 18,
      "title": "📊 Captcha & skipped rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(captcha_detections_total[5m])", "legendFormat": "captcha", "refId": "A" },
        { "expr": "rate(parser_items_skipped_total[5m])", "legendFormat": "skipped: {{cinema}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "cps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 }
    },
    {
      "id": 9004,
      "title": "🔌 Подключения",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 45 }
    },
    {
      "id": 19,
      "title": "🟢 Статус подключений",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "connection_status", "legendFormat": "{{resource}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.5 }] }, "mappings": [{ "type": "value", "options": { "0": { "text": "🔴 DOWN" }, "1": { "text": "✅ UP" } } }], "unit": "none" } },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 46 }
    },
    {
      "id": 20,
      "title": "📊 Connection checks rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(connection_checks_total[5m])", "legendFormat": "{{resource}} {{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "cps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 50 }
    },
    {
      "id": 9005,
      "title": "📋 Логи парсинга (Loki)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 }
    },
    {
      "id": 21,
      "title": "🎬 Логи Celery Worker",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{ "expr": "{service=\"celery-worker\"} | json", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogsMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 59 }
    },
    {
      "id": 22,
      "title": "📋 ИТОГИ парсинга",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "targets": [{ "expr": "{service=\"celery-worker\"} |= \"ИТОГИ\" | json", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogsMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 59 }
    },
    {
      "id": 9006,
      "title": "🖥 Сервер (node_exporter + cAdvisor)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 }
    },
    {
      "id": 30,
      "title": "🧠 CPU usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 85 }] },
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 70 }
    },
    {
      "id": 31,
      "title": "🧠 CPU load (1m/5m/15m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_load1", "legendFormat": "1m", "refId": "A" },
        { "expr": "node_load5", "legendFormat": "5m", "refId": "B" },
        { "expr": "node_load15", "legendFormat": "15m", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "none" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 5, "w": 8, "x": 4, "y": 70 }
    },
    {
      "id": 32,
      "title": "💾 RAM usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 70 }
    },
    {
      "id": 33,
      "title": "💾 RAM usage over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total", "refId": "A" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available", "refId": "B" },
        { "expr": "node_memory_MemFree_bytes", "legendFormat": "Free", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "bytes" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 70 }
    },
    {
      "id": 34,
      "title": "💽 Disk usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"\"})) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 75 }
    },
    {
      "id": 35,
      "title": "💽 Disk I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[1m])", "legendFormat": "read", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total[1m])", "legendFormat": "written", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "Bps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 5, "w": 8, "x": 4, "y": 75 }
    },
    {
      "id": 36,
      "title": "📦 Docker containers (cAdvisor)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(container_last_seen{name=~\".+\"}) by (name)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Running Containers" }] }
        ]
      },
      "options": { "footer": { "show": false }, "frameIndex": 0, "showHeader": true, "sortBy": [] },
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 75 }
    },
    {
      "id": 37,
      "title": "🌐 Network I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total[1m])", "legendFormat": "rx", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total[1m])", "legendFormat": "tx", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "lineWidth": 2 }, "unit": "Bps" } },
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "gridPos": { "h": 5, "w": 12, "x": 0, "y": 80 }
    },
    {
      "id": 38,
      "title": "⏱ Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "time() - node_boot_time_seconds", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 80 }
    },
    {
      "id": 39,
      "title": "🧵 Open FDs / Processes",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "node_procs_running", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 200 }, { "color": "red", "value": 500 }] },
          "unit": "none"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 80 }
    },
    {
      "id": 40,
      "title": "🌡 CPU Temperature",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "node_hwmon_temp_celsius", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 80 }] },
          "unit": "celsius"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 80 }
    }
  ]

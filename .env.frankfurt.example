# ключ телеграм бота
BOT_SECRET_KEY=your_telegram_bot_token_here

# админ телеграм id
ADMIN_TELEGRAM_ID=your_admin_telegram_id

# токен для доступа к Kinopoisk Api Unofficial
KINOPOISK_API_KEY=your_kinopoisk_api_key

GIGACHAT_API_KEY=your_gigachat_api_key

# Настройки для подключения к сервисам
# Замените MOSCOW_SERVER_IP на реальный IP сервера в Москве
REMOTE_SELENIUM_URL=http://MOSCOW_SERVER_IP:3000/webdriver

# Redis с паролем (должен совпадать с docker-compose.frankfurt.yml)
CELERY_BROKER_URL=redis://:SUPER_SECRET_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:SUPER_SECRET_PASSWORD@redis:6379/0

# База данных (локально во Франкфурте)
DATABASE_URL=postgresql+psycopg2://cinema_user:cinema_pass@postgres:5432/cinema_db

# Сервис и локация для структурированного логирования
SERVICE_NAME=telegram-bot
SERVER_LOCATION=frankfurt

# Логирование
LOG_LEVEL=INFO  
LOG_FORMAT=json

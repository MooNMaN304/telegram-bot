# ⚠️ Обязательные переменные (должны быть заполнены!)
# Администратор Telegram (ID берется из настроек бота во Франкфурте)
ADMIN_TELEGRAM_ID=your_admin_telegram_id

# Подключение к базе данных на сервере Франкфурта
# Замените FRANKFURT_IP на реальный IP сервера во Франкфурте
DATABASE_URL=postgresql+psycopg2://cinema_user:cinema_pass@FRANKFURT_IP:5432/cinema_db

# токен для доступа к Kinopoisk Api Unofficial (если требуется для парсеров)
KINOPOISK_API_KEY=your_kinopoisk_api_key

GIGACHAT_API_KEY=your_gigachat_api_key

# Адрес Redis на сервере во Франкфурте (замените FRANKFURT_IP на реальный IP/домен)
# Пароль должен совпадать с docker-compose.frankfurt.yml
REDIS_URL=redis://:SUPER_SECRET_PASSWORD@FRANKFURT_IP:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# Настройки Browserless (локально в московском compose)
REMOTE_SELENIUM_URL=http://browserless:3000/webdriver

# Сервис и локация для структурированного логирования
SERVICE_NAME=celery-worker
SERVER_LOCATION=moscow

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json
